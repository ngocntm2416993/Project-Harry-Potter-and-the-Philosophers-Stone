<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="UI.SettingMenuController">
    <children>
        <!-- Ảnh nền chính -->
        <ImageView fitHeight="768.0" fitWidth="1024.0" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@bg.jpg"/></image>
        </ImageView>

        <!-- Khung setting -->
        <ImageView fitHeight="600.0" fitWidth="800.0" layoutX="112.0" layoutY="84.0"
                   pickOnBounds="true" preserveRatio="true">
            <image><Image url="@bgsetting.png"/></image>
        </ImageView>

        <!-- [THÊM MỚI] barfull: nằm đúng vị trí track, clip bằng Java -->
        <!-- layoutX/Y khớp với Slider bên dưới, mouseTransparent để không chặn tương tác -->
        <!-- barfull: fitWidth = đúng bằng prefWidth của Slider -->
        <ImageView fx:id="imgBarFull"
                   layoutX="0.0" layoutY="0.0"
                   fitHeight="32.0" fitWidth="350.0"
                   preserveRatio="false"
                   mouseTransparent="true">
            <image><Image url="@barfull.png"/></image>
        </ImageView>

        <!-- Slider — track (bar.png) vẫn giữ nguyên qua CSS -->
        <Slider fx:id="sliderMusic"
                layoutX="400.0" layoutY="350.0"
                max="100.0" min="0.0"
                prefHeight="40.0" prefWidth="350.0"
                styleClass="custom-slider"
                value="50.0"/>

        <!-- Nút Back -->
        <Button fx:id="btnBack" layoutX="387.0" layoutY="500.0"
                mnemonicParsing="false" onAction="#onBackClicked"
                prefHeight="60.0" prefWidth="250.0"
                style="-fx-background-color: transparent; -fx-cursor: hand;">
            <graphic>
                <ImageView fitHeight="60.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@Start.png"/></image>
                </ImageView>
            </graphic>
        </Button>
    </children>
</AnchorPane>